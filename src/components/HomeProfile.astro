---
import { Icon } from "astro-icon/components";
import PretextIntro from "./PretextIntro.svelte";

const intro =
	"浙江大学网络空间安全博士在读，研究方向关注大模型与生成式模型安全。近期工作包括 JANUS，一个通过分布优化越狱文生图模型的轻量框架。";

const highlights = [
	["Current", "Ph.D. student, Zhejiang University"],
	["Major", "Cybersecurity"],
	["Advisor", "Zhan Qin"],
	["Location", "Hangzhou, Zhejiang"],
];

const education = [
	{
		degree: "博士（在读）",
		school: "浙江大学",
		meta: "网络空间安全 · 2024.09 - 2029.09（预期）",
	},
	{
		degree: "本科",
		school: "浙江大学",
		meta: "竺可桢学院混合班 · 计算机科学与技术 · 2020.09 - 2024.07",
	},
];

const work = [
	"JANUS: A Lightweight Framework for Jailbreaking Text-to-Image Models via Distribution Optimization, CVPR 2026.",
];

const skills = ["C", "C++", "Python", "Docker", "Linux", "SQL", "Bash", "HTML"];
---

<section class="card-base profile-home">
	<div class="profile-header">
		<div>
			<p class="eyebrow">Zhejiang University</p>
			<h1>郑昊伦</h1>
			<p class="roman-name">Haolun Zheng</p>
		</div>
		<div class="contact-actions" aria-label="Contact links">
			<a href="mailto:h1zh3ng@zju.edu.cn" class="btn-regular contact-btn">
				<Icon name="fa6-regular:envelope" />
				Email
			</a>
			<a href="https://github.com/dimshimmer/" target="_blank" rel="noopener" class="btn-regular contact-btn">
				<Icon name="fa6-brands:github" />
				GitHub
			</a>
		</div>
	</div>

	<div class="intro-block">
		<PretextIntro text={intro} client:load />
	</div>

	<div class="summary-grid">
		{highlights.map(([label, value]) => (
			<div class="summary-item">
				<span>{label}</span>
				<strong>{value}</strong>
			</div>
		))}
	</div>

	<div class="content-grid">
		<section class="info-section">
			<h2>Education</h2>
			<div class="timeline">
				{education.map((item) => (
					<div class="timeline-item">
						<div>
							<strong>{item.degree}</strong>
							<span>{item.school}</span>
						</div>
						<p>{item.meta}</p>
					</div>
				))}
			</div>
		</section>

		<section class="info-section">
			<h2>Research & Awards</h2>
			<ul class="clean-list">
				{work.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		</section>
	</div>

	<section class="info-section skills-section">
		<h2>Skills</h2>
		<div class="skill-list">
			{skills.map((skill) => (
				<span>{skill}</span>
			))}
		</div>
	</section>
</section>

<style>
.profile-home {
	padding: 2rem;
}

.profile-header {
	align-items: flex-start;
	display: flex;
	gap: 1.5rem;
	justify-content: space-between;
}

.eyebrow {
	color: var(--primary);
	font-size: 0.82rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	margin: 0 0 0.5rem;
	text-transform: uppercase;
}

h1 {
	color: rgb(23 23 23 / 0.92);
	font-size: clamp(2.25rem, 5vw, 4.5rem);
	font-weight: 800;
	letter-spacing: 0;
	line-height: 1;
	margin: 0;
}

:global(.dark) h1 {
	color: rgb(255 255 255 / 0.94);
}

.roman-name {
	color: rgb(23 23 23 / 0.55);
	font-size: 1.1rem;
	font-weight: 600;
	margin: 0.75rem 0 0;
}

:global(.dark) .roman-name {
	color: rgb(255 255 255 / 0.58);
}

.contact-actions {
	display: flex;
	flex-wrap: wrap;
	gap: 0.65rem;
	justify-content: flex-end;
	max-width: 24rem;
}

.contact-btn {
	border-radius: 0.5rem;
	font-weight: 700;
	gap: 0.5rem;
	height: 2.75rem;
	padding: 0 0.95rem;
}

.contact-btn :global(svg) {
	font-size: 1rem;
}

.intro-block {
	border-bottom: 1px solid var(--line-divider);
	border-top: 1px solid var(--line-divider);
	margin: 2rem 0 1.5rem;
	padding: 1.35rem 0;
}

.summary-grid {
	display: grid;
	gap: 0.75rem;
	grid-template-columns: repeat(4, minmax(0, 1fr));
	margin-bottom: 1.75rem;
}

.summary-item {
	background: rgb(0 0 0 / 0.035);
	border: 1px solid rgb(0 0 0 / 0.055);
	border-radius: 0.5rem;
	display: flex;
	flex-direction: column;
	gap: 0.25rem;
	min-height: 5.25rem;
	padding: 0.9rem;
}

:global(.dark) .summary-item {
	background: rgb(255 255 255 / 0.055);
	border-color: rgb(255 255 255 / 0.08);
}

.summary-item span {
	color: rgb(23 23 23 / 0.45);
	font-size: 0.78rem;
	font-weight: 700;
	text-transform: uppercase;
}

.summary-item strong {
	color: rgb(23 23 23 / 0.82);
	font-size: 0.98rem;
	line-height: 1.35;
}

:global(.dark) .summary-item span {
	color: rgb(255 255 255 / 0.45);
}

:global(.dark) .summary-item strong {
	color: rgb(255 255 255 / 0.84);
}

.content-grid {
	display: grid;
	gap: 1.5rem;
	grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
}

.info-section {
	min-width: 0;
}

.info-section h2 {
	color: rgb(23 23 23 / 0.82);
	font-size: 1rem;
	font-weight: 800;
	letter-spacing: 0;
	margin: 0 0 0.85rem;
}

:global(.dark) .info-section h2 {
	color: rgb(255 255 255 / 0.86);
}

.timeline,
.clean-list {
	border-left: 2px solid var(--line-divider);
	margin: 0;
	padding-left: 1rem;
}

.timeline {
	display: flex;
	flex-direction: column;
	gap: 1rem;
}

.timeline-item div {
	align-items: baseline;
	display: flex;
	flex-wrap: wrap;
	gap: 0.45rem;
}

.timeline-item strong,
.timeline-item span,
.clean-list li {
	color: rgb(23 23 23 / 0.78);
}

:global(.dark) .timeline-item strong,
:global(.dark) .timeline-item span,
:global(.dark) .clean-list li {
	color: rgb(255 255 255 / 0.78);
}

.timeline-item p {
	color: rgb(23 23 23 / 0.52);
	line-height: 1.55;
	margin: 0.35rem 0 0;
}

:global(.dark) .timeline-item p {
	color: rgb(255 255 255 / 0.54);
}

.clean-list {
	display: flex;
	flex-direction: column;
	gap: 0.75rem;
	list-style: none;
}

.clean-list li {
	line-height: 1.58;
}

.skills-section {
	border-top: 1px solid var(--line-divider);
	margin-top: 1.75rem;
	padding-top: 1.35rem;
}

.skill-list {
	display: flex;
	flex-wrap: wrap;
	gap: 0.55rem;
}

.skill-list span {
	background: var(--btn-regular-bg);
	border-radius: 0.45rem;
	color: var(--btn-content);
	font-weight: 700;
	line-height: 2.1rem;
	padding: 0 0.75rem;
}

@media (max-width: 900px) {
	.profile-header {
		flex-direction: column;
	}

	.contact-actions {
		justify-content: flex-start;
		max-width: none;
	}

	.summary-grid,
	.content-grid {
		grid-template-columns: 1fr 1fr;
	}
}

@media (max-width: 640px) {
	.profile-home {
		padding: 1.25rem;
	}

	.summary-grid,
	.content-grid {
		grid-template-columns: 1fr;
	}

	.contact-btn {
		flex: 1 1 8rem;
	}
}
</style>
